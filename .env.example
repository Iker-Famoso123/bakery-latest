# ── Base de datos (Fase 1) ─────────────────────────────────────────────
# nunca expongas el 5432 fuera de la red local (Cloudflare Tunnel es solo HTTP).
DATABASE_URL="postgresql://rf:rf_dev_password@patio.local:5432/reposteria?schema=public"

# Alternativa si corres Postgres en tu máquina en vez del Pi:
# DATABASE_URL="postgresql://rf:rf_dev_password@localhost:5432/reposteria?schema=public"

# ── API ────────────────────────────────────────────────────────────────
PORT=3000

# ── Auth (Fase 2) ──────────────────────────────────────────────────────
# JWT_ACCESS_SECRET="cambia-esto"
# JWT_REFRESH_SECRET="cambia-esto"
# JWT_ACCESS_TTL="15m"
# JWT_REFRESH_TTL="30d"

# ── Cloudflare R2 (Fase 2) ─────────────────────────────────────────────
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="reposteria-media"
# R2_PUBLIC_URL="https://media.reposteriafamoso.com"
