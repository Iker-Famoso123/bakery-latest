# Copia a `.env.prod` en el Pi y rellena. NO se commitea (git lo ignora).
# Uso: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ── Base de datos ──────────────────────────────────────────
POSTGRES_USER=rf
POSTGRES_PASSWORD=cambia-esto-por-algo-fuerte
POSTGRES_DB=reposteria

# ── Auth ───────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
JWT_ACCESS_SECRET=cambia-esto-por-un-secreto-largo
JWT_ACCESS_TTL=15m
REFRESH_TTL_DAYS=30

# ── Cloudflare R2 ──────────────────────────────────────────
# Ideal: un token DEDICADO para producción (distinto al de desarrollo).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=reposteria-media
# En prod, el dominio propio con CDN:
R2_PUBLIC_URL=https://media.reposteriafamoso.com

# ── Admin (SPA) ────────────────────────────────────────────
# URL pública de la API; se hornea en el bundle del admin al construir.
ADMIN_API_URL=https://api.reposteriafamoso.com

# ── Puertos publicados en el Pi ────────────────────────────
# Cámbialos si chocan con otros contenedores (el túnel/NPM apuntan a estos).
API_PORT=3001
PUBLIC_PORT=4321
ADMIN_PORT=8082
