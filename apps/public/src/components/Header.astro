---
import Concha from './Concha.astro';

const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/blog', label: 'Blog' },
  { href: '/menu', label: 'Menú' },
  { href: '/nosotros', label: 'Nosotros' },
];
---

<header class="sticky top-0 z-30 border-b border-linea bg-masa/85 backdrop-blur-xl">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-3 px-4 py-3 sm:px-5">
    <a href="/" class="flex items-center gap-2.5">
      <Concha class="size-8 shrink-0 text-concha" />
      <span class="hidden font-display text-lg leading-none text-cafe sm:inline">
        Repostería <span class="font-semibold text-concha-hondo">Famoso</span>
      </span>
    </a>
    <nav class="flex items-center gap-0.5 text-sm sm:gap-1">
      {
        links.map((link) =>
          isActive(link.href) ? (
            <a
              href={link.href}
              aria-current="page"
              class="relative rounded-full px-3 py-2 font-medium text-concha-hondo"
            >
              {/* La píldora morfea entre páginas gracias al ClientRouter */}
              <span
                class="absolute inset-0 rounded-full bg-concha-tenue"
                transition:name="nav-activo"
                aria-hidden="true"
              />
              <span class="relative">{link.label}</span>
            </a>
          ) : (
            <a
              href={link.href}
              class="rounded-full px-3 py-2 font-medium text-cafe-suave transition-colors duration-200 hover:bg-masa-hondo hover:text-cafe"
            >
              {link.label}
            </a>
          ),
        )
      }
    </nav>
  </div>
</header>
