---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada">
  <section class="mx-auto max-w-xl px-5 py-24 text-center">
    <p class="font-display text-6xl text-concha">404</p>
    <h1 class="mt-3 font-display text-3xl text-cafe">Esta página no existe</h1>
    <p class="mt-2 text-cafe-suave">Quizá el enlace cambió o el aviso ya no está vigente.</p>
    <a
      href="/"
      class="mt-6 inline-block rounded-full bg-concha px-6 py-3 font-medium text-white hover:bg-concha-hondo"
    >
      Ir al inicio
    </a>
  </section>
</Layout>
