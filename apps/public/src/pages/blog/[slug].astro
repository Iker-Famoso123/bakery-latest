---
import Layout from '../../layouts/Layout.astro';
import { formatDate } from '../../lib/format';
import { getPost, safe } from '../../lib/api';
import { renderTiptap } from '../../lib/tiptap';

const { slug } = Astro.params;
const post = slug ? await safe(getPost(slug), null) : null;

if (!post) {
  Astro.response.status = 404;
}

const html = post ? renderTiptap(post.body) : '';
const excerpt = html.replace(/<[^>]+>/g, '').slice(0, 155).trim();
---

{
  post ? (
    <Layout title={post.title} description={excerpt || undefined} image={post.coverImage ?? undefined}>
      <article class="mx-auto max-w-2xl px-5 py-12">
        <a href="/blog" class="text-sm font-medium text-concha-hondo hover:underline">
          ← Volver al blog
        </a>
        <h1 class="mt-4 font-display text-4xl leading-tight text-cafe">{post.title}</h1>
        <time datetime={post.publishAt} class="mt-3 block text-sm text-tenue">
          {formatDate(post.publishAt)}
        </time>
        {post.coverImage ? (
          <img
            src={post.coverImage}
            alt={post.title}
            class="mt-6 w-full rounded-2xl border border-linea object-cover"
            transition:name={`post-${post.slug}`}
          />
        ) : null}
        <div class="prosa mt-8" set:html={html} />
      </article>
    </Layout>
  ) : (
    <Layout title="No encontrado">
      <section class="mx-auto max-w-xl px-5 py-24 text-center">
        <h1 class="font-display text-4xl text-cafe">Aviso no encontrado</h1>
        <p class="mt-3 text-cafe-suave">
          Puede que ya no esté vigente o que el enlace sea incorrecto.
        </p>
        <a
          href="/blog"
          class="mt-6 inline-block rounded-full bg-concha px-6 py-3 font-medium text-white hover:bg-concha-hondo"
        >
          Volver al blog
        </a>
      </section>
    </Layout>
  )
}
