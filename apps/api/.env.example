# ── Base de datos ──────────────────────────────────────────
# Debe coincidir con las credenciales de docker-compose.yml.
DATABASE_URL="postgresql://usuario:password@localhost:5432/reposteria?schema=public"

PORT=3000

# ── Auth ───────────────────────────────────────────────────
# Genera uno con: openssl rand -hex 32   (mínimo 16 caracteres)
JWT_ACCESS_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_ACCESS_TTL="15m"
REFRESH_TTL_DAYS=30

# ── Cloudflare R2 (Bloque E — subida de imágenes) ──────────
# Opcionales: sin ellas la API arranca, pero /media/upload responde 503.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="reposteria-media"
R2_PUBLIC_URL="https://media.reposteriafamoso.com"
