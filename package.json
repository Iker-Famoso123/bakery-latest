{
  "name": "reposteria-famoso",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @rf/api db:generate",
    "db:migrate": "pnpm --filter @rf/api db:migrate",
    "db:deploy": "pnpm --filter @rf/api db:deploy",
    "db:seed": "pnpm --filter @rf/api db:seed",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
